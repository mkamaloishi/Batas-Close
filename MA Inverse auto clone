вЂЋ//+------------------------------------------------------------------+
вЂЋint OnCalculate(const int rates_total,
вЂЋВ В В В В В В В В В В В В В В  const int prev_calculated,
вЂЋВ В В В В В В В В В В В В В В  const datetime &time[],
вЂЋВ В В В В В В В В В В В В В В  const double &open[],
вЂЋВ В В В В В В В В В В В В В В  const double &high[],
вЂЋВ В В В В В В В В В В В В В В  const double &low[],
вЂЋВ В В В В В В В В В В В В В В  const double &close[],
вЂЋВ В В В В В В В В В В В В В В  const long &tick_volume[],
вЂЋВ В В В В В В В В В В В В В В  const long &real_volume[],
вЂЋВ В В В В В В В В В В В В В В  const int &spread[])
вЂЋВ  {
вЂЋВ В  // 1. Scan MA aktif di chart
вЂЋВ В  string currentNames[3] = {"", "", ""};
вЂЋВ В  int maFound = FindActiveMAs(currentNames);
вЂЋВ В  
вЂЋВ В  string statusText = "вњ… [Multi Inverse] Terdeteksi " + IntegerToString(maFound) + " MA: ";
вЂЋВ В  for(int i = 0; i < maFound; i++) statusText += "[" + currentNames[i] + "] ";
вЂЋВ В  if(maFound == 0) statusText = "вќЊ [Multi Inverse]: Pasang indikator MA dulu di chart!";
вЂЋВ В  Comment(statusText);
вЂЋ
вЂЋВ В  // 2. Refresh Handle
вЂЋВ В  for(int i = 0; i < 3; i++)
вЂЋВ В В В  {
вЂЋВ В В В В  if(currentNames[i] != lastMANames[i] || maHandles[i] == INVALID_HANDLE)
вЂЋВ В В В В В В  {
вЂЋВ В В В В В В В  if(maHandles[i] != INVALID_HANDLE)
вЂЋВ В В В В В В В В В В  IndicatorRelease(maHandles[i]);
вЂЋВ В В В В В В В В В В  
вЂЋВ В В В В В В В  if(currentNames[i] != "")
вЂЋВ В В В В В В В В В В  maHandles[i] = ChartIndicatorGet(0, 0, currentNames[i]);
вЂЋВ В В В В В В В  else
вЂЋВ В В В В В В В В В В  maHandles[i] = INVALID_HANDLE;
вЂЋВ В В В В В В В В В В  
вЂЋВ В В В В В В В  lastMANames[i] = currentNames[i];
вЂЋВ В В В В В В  }
вЂЋВ В В В  }
вЂЋ
вЂЋВ В  // 3. Kalkulasi Mundur (MULAI DARI CANDLE PALING AWAL)
вЂЋВ В  // Tentukan start calculation: mulai dari candle 0 sampai rates_total
вЂЋВ В  int start;
вЂЋВ В  if(prev_calculated == 0) start = 0; // Inisialisasi awal
вЂЋВ В  else start = prev_calculated - 1;В В  // Update hanya candle baru
вЂЋВ В  
вЂЋВ В  if(start < 0) start = 0;
вЂЋ
вЂЋВ В  double tempMABuffer[]; // Array penampung data MA
вЂЋ
вЂЋВ В  for(int m = 0; m < 3; m++)
вЂЋВ В В В  {
вЂЋВ В В В В  // Jika MA tidak ada, isi default 0 (agar garis lurus tidak zigzag)
вЂЋВ В В В В  if(maHandles[m] == INVALID_HANDLE)
вЂЋВ В В В В В В  {
вЂЋВ В В В В В В В  for(int i = start; i < rates_total; i++)
вЂЋВ В В В В В В В В В  {
вЂЋВ В В В В В В В В В В  if(m == 0) InverseBuffer1[i] = 0;
вЂЋВ В В В В В В В В В В  else if(m == 1) InverseBuffer2[i] = 0;
вЂЋВ В В В В В В В В В В  else if(m == 2) InverseBuffer3[i] = 0;
вЂЋВ В В В В В В В В В  }
вЂЋВ В В В В В В В  continue;
вЂЋВ В В В В В В  }
вЂЋ
вЂЋВ В В В В  // Copy semua data MA dari candle 0 sampai paling akhir
вЂЋВ В В В В  int copied = CopyBuffer(maHandles[m], 0, 0, rates_total, tempMABuffer);
вЂЋВ В В В В  if(copied <= 0) continue;
вЂЋ
вЂЋВ В В В В  // Loop hitung mundur dari kiri ke kanan
вЂЋВ В В В В  for(int i = start; i < rates_total; i++)
вЂЋВ В В В В В В  {
вЂЋВ В В В В В В В  // Jika data MA kosong di awal candle, biarkan saja (0) agar tidak patah
вЂЋВ В В В В В В В  if(i >= copied || tempMABuffer[i] == EMPTY_VALUE || tempMABuffer[i] == 0)
вЂЋВ В В В В В В В В В  {
вЂЋВ В В В В В В В В В В  if(m == 0) InverseBuffer1[i] = 0;
вЂЋВ В В В В В В В В В В  else if(m == 1) InverseBuffer2[i] = 0;
вЂЋВ В В В В В В В В В В  else if(m == 2) InverseBuffer3[i] = 0;
вЂЋВ В В В В В В В В В В  continue;
вЂЋВ В В В В В В В В В  }
вЂЋ
вЂЋВ В В В В В В В  // Rumus Mirroring yang benar: MA dicerminkan ke atas
вЂЋВ В В В В В В В  double inverseValue = (2.0 * close[i]) - tempMABuffer[i];
вЂЋВ В В В В В В В  
вЂЋВ В В В В В В В  // Masukkan nilai ke buffer
вЂЋВ В В В В В В В  if(m == 0) InverseBuffer1[i] = inverseValue;
вЂЋВ В В В В В В В  else if(m == 1) InverseBuffer2[i] = inverseValue;
вЂЋВ В В В В В В В  else if(m == 2) InverseBuffer3[i] = inverseValue;
вЂЋВ В В В В В В  }
вЂЋВ В В В  }
вЂЋ
вЂЋВ В  return(rates_total);
вЂЋВ  }
